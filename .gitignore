# Dependencies
node_modules/

# Build output (regenerated by `npm run build`)
dist/

# Runtime data (inquiries persisted by the server)
data/
outputs/data/
.e2e-data/

# Playwright (browser binaries live in node_modules; these are run artifacts)
test-results/
playwright-report/
playwright/.cache/

# Local dev/QA artifacts (screenshots, scratch captures)
work/

# Tool scratch directories
.agents/
.codex/

# Server temp files (atomic-write staging)
.inquiries.*.tmp
inquiries.corrupt-*.json

# Environment & secrets
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
