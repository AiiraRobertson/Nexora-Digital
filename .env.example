# Nexora Digital backend configuration.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# All variables are OPTIONAL — the server runs with sane defaults if unset.

# Port the HTTP server listens on.
PORT=3000

# Directory where inquiries.json is persisted.
# Defaults to ./data relative to the project root.
# DATA_DIR=./data

# Bearer token required to read GET /api/inquiries.
# Leave empty to keep the endpoint locked (any request returns 401).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# Comma-separated CORS allowlist, e.g.
#   https://nexoradigital.co,https://www.nexoradigital.co
# Empty means "reflect any origin" (dev convenience); sensitive routes still
# require the admin token, so this does not expose PII.
ALLOWED_ORIGINS=

# Set to 1 ONLY when running behind a proxy you control, so the server trusts
# the X-Forwarded-For header for client-IP rate limiting.
TRUST_PROXY=0

# DeepSeek API key for the LLM-backed support assistant (POST /api/support).
# When unset, the assistant falls back to the local keyword matcher.
DEEPSEEK_API_KEY=

# DeepSeek model to use. Defaults to deepseek-chat.
# DEEPSEEK_MODEL=deepseek-chat
